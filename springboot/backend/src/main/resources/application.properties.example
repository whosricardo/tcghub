# Copy this file to application-local.properties and fill in the values
jwt.secret=your-secret-key-here-must-be-at-least-32-characters
jwt.expiration=86400000
jwt.refresh-expiration=604800000

spring.datasource.url=jdbc:mysql://localhost:3306/tcghub?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=your-password